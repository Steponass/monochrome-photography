{
	"compatibility_date": "2026-04-17",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "monochrome-photography",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "2790add2038b46e098cb5124efdaa861"
    }
  ]
}