---
import Layout from '../layouts/Layout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import ProductLightbox from '../islands/ProductLightbox.svelte';
import { getCollection } from 'astro:content';

const products = await getCollection('products', ({ data }) => {
  return data.category === 'urban';
});

products.sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const galleryProducts = products.map(({ data }) => ({
  image: data.image,
  alt: data.alt,
  title: data.title,
  slug: data.slug,
  aspectRatio: data.aspectRatio,
}));
---

<Layout title="Urban Photography">
  <div class="photo-page-title-container">
  <h1 class="photo-page-title">Urban</h1>
  </div>
  <GalleryGrid products={galleryProducts} pattern="2-3" />
  <ProductLightbox client:load />
</Layout>