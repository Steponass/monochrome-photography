---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Order received — Thank you">
  <main class="order-page">
    <h1>Thank you for your order</h1>
    <p>
      You'll receive a confirmation email shortly with your order details.
      Please allow a few moments for it to arrive.
    </p>
    <p class="order-note">
      If you have any questions, just get in touch.
    </p>
    <a href="/" class="order-link">Back to gallery</a>
  </main>
</Layout>

<script>
  import { clearCart } from '../../stores/cartStore.js';

  /**
   * Clear the cart when the success page loads with a session_id parameter.
   *
   * The session_id comes from Stripe's redirect — its presence means
   * the user arrived here via checkout, not by typing the URL directly.
   *
   * This is a UX convenience, NOT proof of payment.
   * Only the webhook (Phase 5) confirms payment actually occurred.
   */
  const params = new URLSearchParams(window.location.search);

  if (params.has('session_id')) {
    clearCart();
  }
</script>

<style>
  .order-page {
    margin-inline: auto;
    padding-inline: var(--space-12-16px);
    padding-block: var(--space-64-96px);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-16-24px);
    align-items: center;
  }

  .order-note {
    font-size: var(--fontsize-body-s);
  }

  .order-link {
    display: inline-block;
    padding: var(--space-12-16px) var(--space-24-32px);
    border: 1px solid var(--clr-stroke-weak);
    border-radius: var(--radius-5px);
    transition: border-color var(--transition-2);
  }

</style>