---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Order cancelled">
  <main class="order-page">
    <h1>Order not completed</h1>
    <p>
      Your payment was not processed and you have not been charged.
      Your cart is still available if you'd like to try again.
    </p>
    <a href="/" class="order-link">Back to gallery</a>
  </main>
</Layout>

<style>
  .order-page {
    margin-inline: auto;
    padding-inline: var(--space-12-16px);
    padding-block: var(--space-64-96px);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-16-24px);
    align-items: center;
  }

  .order-link {
    display: inline-block;
    padding: var(--space-12-16px) var(--space-24-32px);
    border: 1px solid var(--clr-stroke-weak);
    border-radius: var(--radius-5px);
    transition: border-color var(--transition-2);
  }

  .order-link:hover {
    border-color: var(--clr-primary);
  }
</style>