---
import Layout from '../layouts/Layout.astro';
import Lightbox from '../components/Lightbox.astro';

const images = [
  { src: '/photos/in-situ/In_situ_missing_the_pig.webp', alt: 'Framed photo of the Battersea Power Plant', title: 'Missing the Pig' },
  { src: '/photos/in-situ/In_situ_flood_sentinels.webp', alt: 'Framed photo of the Thames Barrier', title: 'Flood Sentinels' },
  { src: '/photos/in-situ/In_situ_burlington_arcade.webp', alt: 'Framed photo of Burlington Arcade', title: 'Burlington Arcade' },
  { src: '/photos/in-situ/In_situ_royal_albert_hall.webp', alt: 'Framed photo of Royal Albert Hall', title: 'Royal Albert Hall' },
  { src: '/photos/in-situ/In_situ_O2_and_palace_of_westminster.webp', alt: 'Two framed photos hanging in an art gallery', title: 'O2 / Palace of Westminster I' },
  { src: '/photos/in-situ/In_situ_O2.webp', alt: 'Framed photo of O2 arena in London', title: 'O2' },
  { src: '/photos/in-situ/In_situ_abduction_of_the_pine_cone.webp', alt: 'Framed photo of a pine cone in the dark', title: 'Abduction of the Pine Cone' },
  { src: '/photos/in-situ/In_situ_02_St_Pauls_2.webp', alt: 'Framed photo inside a display window', title: 'St Paul\'s II' },
];
---

<Layout title="In Situ — Fine Art Prints in Context">
  <main>
    <div class="photo-page-title-container">
      <h1>In situ</h1>
    </div>

    <div class="in-situ-grid">
      {images.map((image, index) => (
        <button
          class="in-situ-item"
          type="button"
          data-index={index}
          aria-label={`View enlarged: ${image.alt}`}
        >
          <img src={image.src} alt={image.alt} loading="lazy" />
        </button>
      ))}
    </div>
  </main>

  <Lightbox />
</Layout>

<script define:vars={{ images }}>
  const grid = document.querySelector('.in-situ-grid');

  grid.addEventListener('click', (event) => {
    const item = event.target.closest('.in-situ-item');
    if (!item) return;

    const startIndex = parseInt(item.dataset.index, 10);

    document.dispatchEvent(
      new CustomEvent('lightbox:open', {
        detail: { images, startIndex },
      })
    );
  });
</script>

<style>
  
  main {
    max-width: 946px;
    margin-inline: auto;
    margin-block-end: 48px;
  }

  .photo-page-title-container {
  margin-top: var(--space-32-48px);
  width: min(100%, 1536px);
  padding-inline: var(--space-12-16px);
  font-size: var(--fontsize-h4);
  margin-inline: auto;
  h1 {
    font-size: var(--fontsize-h4);
    margin-bottom: var(--space-24-32px);
    @media (max-width: 440px) {
      text-align: center;
    }
  }
  }

  .in-situ-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-32px);
    padding-inline: var(--space-12-16px);

    @media (max-width: 440px) {
      grid-template-columns: 1fr;
      row-gap: var(--space-24px);
      column-gap: 0;
    }
  }

  .in-situ-item {
    background-color: var(--color-stroke-weak);
    border: none;
    cursor: pointer;
    overflow: hidden;
    border-radius: var(--radius-3px);
  }

  .in-situ-item img {
    width: 100%;
    height: 100%;
    max-height: 555px;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-3px);
    pointer-events: none;
    transition: transform 0.3s ease;
  }

  .in-situ-item:hover img {
    transform: scale(1.02);
  }
</style>