---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface GalleryProduct {
  image: ImageMetadata;
  alt: string;
  title: string;
  slug: string;
  aspectRatio: string;
}

interface Props {
  products: GalleryProduct[];
  pattern?: '2-3' | '3-2';
}

const { products, pattern = '2-3' } = Astro.props;

/**
 * Build a serializable array for the lightbox.
 * The Svelte island needs plain URL strings, not ImageMetadata objects.
 */
const lightboxProducts = products.map(({ image, alt, title, slug, aspectRatio }) => ({
  imageSrc: image.src,
  alt,
  title,
  slug,
  aspectRatio,
}));
---

<div
  class:list={['gallery-grid', `gallery-grid--${pattern}`]}
  data-lightbox-products={JSON.stringify(lightboxProducts)}
>
  {products.map(({ image, alt, title }, index) => (
    <button
      class="gallery-item"
      type="button"
      data-index={index}
      aria-label={`View enlarged: ${alt}`}
    >
      <Image
        src={image}
        alt={alt}
        loading="lazy"
        widths={[400, 800, 1200]}
        sizes="(max-width: 440px) 100vw, (max-width: 1024px) 50vw, 33vw"
      />
      <span class="gallery-item-title">{title}</span>
    </button>
  ))}
</div>

<script>
  import { openLightbox } from '../stores/lightboxStore.js';

  const grid = document.querySelector('.gallery-grid') as HTMLElement | null;
  if (!grid) throw new Error('GalleryGrid: .gallery-grid element not found');

  const products = JSON.parse(grid.dataset.lightboxProducts ?? '[]');

  grid.addEventListener('click', (event: MouseEvent) => {
    const target = event.target as HTMLElement;
    const item = target.closest('.gallery-item') as HTMLElement | null;
    if (!item) return;

    const startIndex = parseInt(item.dataset.index ?? '0', 10);
    openLightbox(products, startIndex);
  });
</script>

<style>

  
  /* ——— Grid layout ——— */

  .gallery-grid {
    width: min(100%, 1536px);
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-24-32px);
    padding-inline: var(--space-12-16px);
    margin-inline: auto;
    margin-block-end: var(--space-64-96px);
    @media (max-width: 440px) {
      grid-template-columns: 1fr;
    }
  }

  /* Pattern: 2-3 (default) */
  .gallery-grid--2-3 > .gallery-item {
    grid-column: span 3;

    @media (max-width: 440px) {
      grid-column: span 1;
    }
  }

  .gallery-grid--2-3 > .gallery-item:nth-child(5n),
  .gallery-grid--2-3 > .gallery-item:nth-child(5n - 1),
  .gallery-grid--2-3 > .gallery-item:nth-child(5n - 2) {
    grid-column: span 2;

    @media (max-width: 440px) {
      grid-column: span 1;
    }
  }

  /* Pattern: 3-2 */
  .gallery-grid--3-2 > .gallery-item {
    grid-column: span 2;

    @media (max-width: 440px) {
      grid-column: span 1;
    }
  }

  .gallery-grid--3-2 > .gallery-item:nth-child(5n),
  .gallery-grid--3-2 > .gallery-item:nth-child(5n - 1) {
    grid-column: span 3;

    @media (max-width: 440px) {
      grid-column: span 1;
    }
  }

  /* ——— Gallery item ——— */

  .gallery-item {
    position: relative;
    background-color: var(--color-stroke-weak);
    border: none;
    overflow: hidden;
    border-radius: var(--radius-sm);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-3px);
    pointer-events: none;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.01);

  }

  /* ——— Title overlay ——— */

  .gallery-item-title {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-12px);
    background: var(--clr-backdrop);
    text-align: center;
    opacity: 0;
    transition: var(--transition-2);
    pointer-events: none;
  }

  @media (hover: hover) {
  .gallery-item:hover .gallery-item-title,
  .gallery-item:focus-visible .gallery-item-title {
    opacity: 1;
  }
  }
</style>