---

interface GalleryImage {
  src: string;
  alt: string;
  title: string;
}

interface Props {
  images: GalleryImage[];
  pattern?: '2-3' | '3-2';
}

const { images, pattern = '2-3' } = Astro.props;
---

<div class:list={['gallery-grid', `gallery-grid--${pattern}`]}>
  {images.map((image, index) => (
    <button
      class="gallery-item"
      type="button"
      data-index={index}
      aria-label={`View enlarged: ${image.alt}`}
    >
      <img src={image.src} alt={image.alt} loading="lazy" />
      <span class="gallery-item-title">{image.title}</span>
    </button>
  ))}
</div>

<script define:vars={{ images }}>
  const grid = document.querySelector('.gallery-grid');

  grid.addEventListener('click', (event) => {
    const item = event.target.closest('.gallery-item');
    if (!item) return;

    const startIndex = parseInt(item.dataset.index, 10);

    document.dispatchEvent(
      new CustomEvent('lightbox:open', {
        detail: { images, startIndex },
      })
    );
  });
</script>

<style>

  
  /* ——— Grid layout ——— */

  .gallery-grid {
    width: min(100%, 1536px);
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-24-32px);
    padding-inline: var(--space-12-16px);
    margin-inline: auto;
    margin-block-end: var(--space-64-96px);
    @media (max-width: 440px) {
      grid-template-columns: 1fr;
    }
  }

  /* Pattern: 2-3 (default) */
  .gallery-grid--2-3 > .gallery-item {
    grid-column: span 3;

    @media (max-width: 440px) {
      grid-column: span 1;
    }
  }

  .gallery-grid--2-3 > .gallery-item:nth-child(5n),
  .gallery-grid--2-3 > .gallery-item:nth-child(5n - 1),
  .gallery-grid--2-3 > .gallery-item:nth-child(5n - 2) {
    grid-column: span 2;

    @media (max-width: 440px) {
      grid-column: span 1;
    }
  }

  /* Pattern: 3-2 */
  .gallery-grid--3-2 > .gallery-item {
    grid-column: span 2;

    @media (max-width: 440px) {
      grid-column: span 1;
    }
  }

  .gallery-grid--3-2 > .gallery-item:nth-child(5n),
  .gallery-grid--3-2 > .gallery-item:nth-child(5n - 1) {
    grid-column: span 3;

    @media (max-width: 440px) {
      grid-column: span 1;
    }
  }

  /* ——— Gallery item ——— */

  .gallery-item {
    position: relative;
    background-color: var(--color-stroke-weak);
    border: none;
    overflow: hidden;
    border-radius: var(--radius-sm);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-3px);
    pointer-events: none;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.01);

  }

  /* ——— Title overlay ——— */

  .gallery-item-title {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-8px);
    background: var(--clr-bg);
    text-align: center;
    opacity: 0;
    transition: var(--transition-2);
    pointer-events: none;
  }

  @media (hover: hover) {
  .gallery-item:hover .gallery-item-title,
  .gallery-item:focus-visible .gallery-item-title {
    opacity: 1;
  }
  }
</style>