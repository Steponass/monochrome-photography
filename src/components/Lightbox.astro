<dialog class="lightbox" aria-label="Enlarged photo">
  <button
    class="lightbox-nav lightbox-nav-prev"
    type="button"
    aria-label="Previous photo"
  >
    ‹
  </button>

  <div class="lightbox-media">
    <img class="lightbox-image" src="" alt="" />
    <span class="lightbox-image-title"></span>
  </div>

  <button
    class="lightbox-nav lightbox-nav-next"
    type="button"
    aria-label="Next photo"
  >
    ›
  </button>

  <button class="lightbox-close" type="button" aria-label="Close lightbox">
    ✕
  </button>
</dialog>

<script>
  interface LightboxImage {
    src: string;
    alt: string;
    title: string;
  }

  interface LightboxOpenDetail {
    images: LightboxImage[];
    startIndex: number;
  }

  const dialog = document.querySelector('.lightbox') as HTMLDialogElement;
  const image = dialog.querySelector('.lightbox-image') as HTMLImageElement;
  const imageTitle = dialog.querySelector('.lightbox-image-title') as HTMLSpanElement;
  const closeButton = dialog.querySelector('.lightbox-close') as HTMLButtonElement;
  const prevButton = dialog.querySelector('.lightbox-nav-prev') as HTMLButtonElement;
  const nextButton = dialog.querySelector('.lightbox-nav-next') as HTMLButtonElement;

  let currentImages: LightboxImage[] = [];
  let currentIndex: number = 0;

  /* ——— Display ——— */

  function showCurrentImage(): void {
    const current = currentImages[currentIndex];
    image.src = current.src;
    image.alt = current.alt;
    imageTitle.textContent = current.title;

    /* Hide nav buttons at the ends rather than wrapping around.
     * Wrapping is disorienting when you don't know how many images exist. */
    prevButton.hidden = currentIndex === 0;
    nextButton.hidden = currentIndex === currentImages.length - 1;
  }

  /* ——— Navigation ——— */

  function goToPrevious(): void {
    if (currentIndex > 0) {
      currentIndex -= 1;
      document.documentElement.dataset.lightboxDir = 'prev';

      if ('startViewTransition' in document) {
        (document as any).startViewTransition(() => showCurrentImage());
      } else {
        showCurrentImage();
      }
    }
  }

  function goToNext(): void {
    if (currentIndex < currentImages.length - 1) {
      currentIndex += 1;
      document.documentElement.dataset.lightboxDir = 'next';

      if ('startViewTransition' in document) {
        (document as any).startViewTransition(() => showCurrentImage());
      } else {
        showCurrentImage();
      }
    }
  }

  prevButton.addEventListener('click', goToPrevious);
  nextButton.addEventListener('click', goToNext);

  /* ——— Keyboard navigation ——— */

  dialog.addEventListener('keydown', (event: KeyboardEvent) => {
    if (event.key === 'ArrowLeft') {
      event.preventDefault();
      goToPrevious();
    }

    if (event.key === 'ArrowRight') {
      event.preventDefault();
      goToNext();
    }
  });

  /* ——— Touch/swipe navigation ——— */

  const SWIPE_THRESHOLD_PX: number = 50;
  let touchStartX: number = 0;

  dialog.addEventListener('touchstart', (event: TouchEvent) => {
    touchStartX = event.touches[0].clientX;
  }, { passive: true });

  dialog.addEventListener('touchend', (event: TouchEvent) => {
    const touchEndX = event.changedTouches[0].clientX;
    const deltaX = touchEndX - touchStartX;

    if (Math.abs(deltaX) < SWIPE_THRESHOLD_PX) return;

    if (deltaX > 0) {
      goToPrevious(); /* Swipe right = go back */
    } else {
      goToNext();     /* Swipe left = go forward */
    }
  }, { passive: true });

  /* ——— Open / Close ——— */

  closeButton.addEventListener('click', () => {
    dialog.close();
  });

  dialog.addEventListener('click', (event: MouseEvent) => {
    if (event.target === dialog) {
      dialog.close();
    }
  });

  document.addEventListener('lightbox:open', ((event: CustomEvent<LightboxOpenDetail>) => {
    currentImages = event.detail.images;
    currentIndex = event.detail.startIndex;
    showCurrentImage();
    dialog.showModal();
  }) as EventListener);
</script>

<style>
  .lightbox[open] {
    border: none;
    background: transparent;
    position: fixed;
    width: 100dvw;
    height: 100dvh;
    margin-inline: auto;
    display: grid;
    place-content: center;
    opacity: 1;
    @starting-style {
      opacity: 0;
    }
  }

  .lightbox {
    opacity: 0;
    transition: var(--transition-2);
  }

  .lightbox::backdrop {
    background: var(--clr-backdrop);
  }

  .lightbox-media {
    position: relative;
    max-width: 95dvw;
    max-height: 95dvh;
    transition: var(--transition-1);
  }

  .lightbox-image {
    max-width: 100%;
    max-height: 95dvh;
    object-fit: contain;
    display: block;

  }

  .lightbox-image-title {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: var(--space-8px);
    font-size: var(--fontsize-h5);
    background: var(--clr-backdrop);
    text-align: center;
    transition: var(--transition-1);
  }

  .lightbox-close {
    position: fixed;
    top: var(--space-12-16px);
    right: var(--space-12-16px);
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: var(--space-8px);
    line-height: 1;
  }

  .lightbox-nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    padding: var(--space-12-16px);
    line-height: 1;
  }

  .lightbox-nav-prev {
    left: var(--space-12-16px);
  }

  .lightbox-nav-next {
    right: var(--space-12-16px);
  }

  .lightbox-nav[hidden] {
    display: none;
  }
</style>

<style is:global>
  /* Directional slide animations for image transitions.
   * Must be global because ::view-transition-* pseudo-elements
   * live at the document level and can't be Astro-scoped. */

  :root[data-lightbox-dir="next"]::view-transition-old(lightbox-image) {
    animation: lightbox-slide-out-left 1.4s ease both;
  }
  :root[data-lightbox-dir="next"]::view-transition-new(lightbox-image) {
    animation: lightbox-slide-in-right 1.4s ease both;
  }

  :root[data-lightbox-dir="prev"]::view-transition-old(lightbox-image) {
    animation: lightbox-slide-out-right 1.4s ease both;
  }
  :root[data-lightbox-dir="prev"]::view-transition-new(lightbox-image) {
    animation: lightbox-slide-in-left 1.4s ease both;
  }

  @keyframes lightbox-slide-out-left {
    to { transform: translateX(-18%); opacity: 0; }
  }
  @keyframes lightbox-slide-in-right {
    from { transform: translateX(18%); opacity: 0; }
  }
  @keyframes lightbox-slide-out-right {
    to { transform: translateX(18%); opacity: 0; }
  }
  @keyframes lightbox-slide-in-left {
    from { transform: translateX(-18%); opacity: 0; }
  }
</style>