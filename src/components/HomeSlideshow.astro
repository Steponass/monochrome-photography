---

const slides = [
  {
    desktop: '/slideshow/1-desktop-UR043d.avif',
    mobile: '/slideshow/1-mobile-IN050d_Large_Golden_Jubilee_Bridge.avif',
  },
  {
    desktop: '/slideshow/2-desktop-UR020c.avif',
    mobile: '/slideshow/2-mobile-IN055f_Large_Atomium_III.avif',
  },
  {
    desktop: '/slideshow/3-desktop-UR022c.avif',
    mobile: '/slideshow/3-mobile-UR070d.avif',
  },
  {
    desktop: '/slideshow/4-desktop-ME053d.avif',
    mobile: '/slideshow/4-mobile-IN021b_Large_Echo_of_the_War.avif',
  },
  {
    desktop: '/slideshow/5-desktop-IN031d.avif',
    mobile: '/slideshow/5-mobile-IN060f_Large_1854.avif',
  },
];

const SLIDE_DURATION_SECONDS = 10;
const CYCLE_DURATION_SECONDS = SLIDE_DURATION_SECONDS * slides.length;

/**
 * Playback order: 1 → 2 → 3 → 4 → 5 → 1 → ...
 *
 * Slides are stacked via position: absolute, so the topmost slide
 * in the DOM is visually in front. When it fades out, it must reveal
 * the NEXT slide — meaning the next slide's fade-in must coincide
 * with the current slide's fade-out.
 *
 * Slide 1 delay = 0 (visible immediately).
 * Slide N delay = (N * SLIDE_DURATION) - CYCLE_DURATION
 *   → gives a negative delay that positions each slide's "visible"
 *     window at the correct point in the 50s cycle.
 */
function calculateDelay(index: number): number {
  if (index === 0) return 0;
  return index * SLIDE_DURATION_SECONDS - CYCLE_DURATION_SECONDS;
}
---

<div class="slideshow">
  {slides.map((slide, index) => (
    <div
      class="slide"
      style={`animation-delay: ${calculateDelay(index)}s`}
    >
      <picture>
        <source media="(min-width: 785px)" srcset={slide.desktop} />
        <img src={slide.mobile} alt='' />
      </picture>
    </div>
  ))}
</div>

<style
  define:vars={{
    cycleDuration: `${CYCLE_DURATION_SECONDS}s`,
  }}
>
  .slideshow {
    position: fixed;
    inset: 0;
    z-index: -10;
    overflow: hidden;
    background-color: var(--clr-blackish);
  }

  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: crossfade var(--cycleDuration) infinite;
  }

  .slide img {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  @keyframes crossfade {
    0%   { opacity: 1; }
    16%  { opacity: 1; }
    24%  { opacity: 0; }
    92%  { opacity: 0; }
    100% { opacity: 1; }
  }
</style>